<script>

function openWebsite(){

document.getElementById("startScreen").style.display="none";

document.getElementById("mainSite").style.display="block";

}

function solveIntegration(){

let func=document.getElementById("func").value;

let x1=parseFloat(document.getElementById("x1").value);

let x2=parseFloat(document.getElementById("x2").value);

let y1=parseFloat(document.getElementById("y1").value);

let y2=parseFloat(document.getElementById("y2").value);

let output=document.getElementById("output");

try{

let expr=math.compile(func);

let dx=(x2-x1)/100;

let dy=(y2-y1)/100;

let sum=0;

for(let x=x1;x<x2;x+=dx){

for(let y=y1;y<y2;y+=dy){

sum += expr.evaluate({x:x,y:y})*dx*dy;

}

}

output.innerHTML=`

<h3>Step-by-Step Solution</h3>

<p><b>Function:</b> ${func}</p>

<p><b>Limits:</b></p>

<p>x : ${x1} to ${x2}</p>

<p>y : ${y1} to ${y2}</p>

<p><b>Step 1:</b> Divide region into small rectangles.</p>

<p><b>Step 2:</b> Evaluate f(x,y) over each rectangle.</p>

<p><b>Step 3:</b> Apply numerical double integration.</p>

<p><b>Final Answer:</b> ${sum.toFixed(4)}</p>

`;

}

catch(error){

output.innerHTML=
"<p style='color:red;'>Invalid Function Input</p>";

}

}

const quiz=[

{
q:"What does double integration calculate?",
o:["Area/Volume","Only Area","Only Perimeter","Matrix"],
a:0
},

{
q:"Symbol of double integration is?",
o:["∬","∑","∫","∆"],
a:0
},

{
q:"Which variable is commonly used?",
o:["x,y","a,b","m,n","p,q"],
a:0
},

{
q:"If f(x,y)=1 then integral gives?",
o:["Area","Volume","Speed","Force"],
a:0
},

{
q:"Double integration is part of?",
o:["Multivariable Calculus","Algebra","Geometry","Statistics"],
a:0
}

];

let current=0;

let score=0;

function loadQuestion(){

document.getElementById("question").innerHTML=
quiz[current].q;

for(let i=0;i<4;i++){

document.getElementById("opt"+i).innerHTML=
quiz[current].o[i];

}

}

function checkAnswer(i){

if(i==quiz[current].a){

score++;

document.getElementById("result").innerHTML=
"Correct Answer";

}

else{

document.getElementById("result").innerHTML=
"Wrong Answer";

}

current++;

if(current<quiz.length){

setTimeout(()=>{

document.getElementById("result").innerHTML="";

loadQuestion();

},1000);

}

else{

document.getElementById("question").innerHTML=
"Quiz Completed";

document.getElementById("result").innerHTML=
"Final Score: "+score+"/"+quiz.length;

}

}

loadQuestion();

let time=60;

setInterval(()=>{

time--;

document.getElementById("timer").innerHTML=
"Time Left: "+time+"s";

if(time<=0){

document.getElementById("timer").innerHTML=
"Time Over";

}

},1000);

</script>

